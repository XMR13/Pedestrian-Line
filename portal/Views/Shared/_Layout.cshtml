<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pedestrian Line Portal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isLoginPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase);
    var currentEventUid = ViewData["CurrentEventUid"]?.ToString();

    var bodyClass = (currentController, currentAction) switch
    {
        ("Events", "ReviewQueue") => "page-review-queue",
        ("Events", "Detail") => "page-event-detail",
        ("Home", "Index") => "page-dashboard",
        _ => "",
    };

    string NavClass(string controller, string action)
    {
        var isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return isActive ? "active" : string.Empty;
    }

    string? AriaCurrent(string controller, string action)
    {
        var isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return isActive ? "page" : null;
    }
}
<body class="@bodyClass">
    <div class="grain"></div>

@if (isLoginPage)
{
    <main class="login-shell">
        @RenderBody()
    </main>
}
else
{
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-visual">
                    <img
                        class="brand-logo"
                        src="~/assets/indah-kiat-logo.png"
                        alt="PT Indah Kiat logo"
                        width="406"
                        height="124"
                        loading="eager"
                        decoding="async"
                        fetchpriority="high"
                        onerror="this.closest('.brand-visual').classList.add('logo-missing');" />
                    <div class="brand-fallback" aria-hidden="true">
                        <div class="mark"></div>
                        <span>logo unavailable</span>
                    </div>
                </div>
                <div>
                    <h1>Traffic Portal</h1>
                    <p class="sub">Live operations workspace</p>
                    <p class="brand-path">Powered by Pedestrian Line Counter</p>
                </div>
            </div>

            <nav class="nav" aria-label="Primary navigation">
                <a class="@NavClass("Home", "Index")" aria-current="@AriaCurrent("Home", "Index")" asp-controller="Home" asp-action="Index">
                    Dashboard <span class="pill ink">LIVE</span>
                </a>
                <a class="@NavClass("Events", "ReviewQueue")" aria-current="@AriaCurrent("Events", "ReviewQueue")" asp-controller="Events" asp-action="ReviewQueue">
                    Review <span class="pill">Y/N</span>
                </a>
                <a class="@NavClass("Events", "Index")" aria-current="@AriaCurrent("Events", "Index")" asp-controller="Events" asp-action="Index">
                    Event Browser
                </a>
                @if (!string.IsNullOrWhiteSpace(currentEventUid))
                {
                    <a class="@NavClass("Events", "Detail")" aria-current="@AriaCurrent("Events", "Detail")" asp-controller="Events" asp-action="Detail" asp-route-eventUid="@currentEventUid">
                        Event Detail
                    </a>
                }
                else
                {
                    <a asp-controller="Events" asp-action="Index">
                        Event Detail
                    </a>
                }
                <a asp-controller="Events" asp-action="ExportCsv">
                    Export <span class="pill">CSV</span>
                </a>
            </nav>

            <div style="margin-top: 16px;">
                <div class="panel">
                    <h3>Session</h3>
                    <div class="meta">
                        <div class="row">
                            <div class="key">Reviewer</div>
                            <div class="val">@(isAuthenticated ? User?.Identity?.Name : "guest")</div>
                        </div>
                        <div class="row">
                            <div class="key">Export</div>
                            <div class="val"><a asp-controller="Events" asp-action="ExportCsv">reviewed CSV</a></div>
                        </div>
                    </div>
                    @if (isAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top: 10px;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn secondary" style="width:100%;">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </aside>

        <main class="content">
            @RenderBody()
        </main>
    </div>
}

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
