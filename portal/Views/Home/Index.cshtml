@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    var pending = Model.TotalPending;
    var reviewed = Model.TotalReviewed;
    var totalObserved = Model.TotalAToB + Model.TotalBToA;
    var queueEstimateMinutes = pending == 0 ? 0 : Math.Max(1, (int)Math.Ceiling((pending * 5.0) / 60.0));
    var reviewCompletion = (pending + reviewed) == 0 ? 0 : (int)Math.Round((reviewed * 100.0) / (pending + reviewed));
    var trendPoints = Model.TrendPoints;
    var trendCount = trendPoints.Count;
    const double trendWidth = 920d;
    const double trendHeight = 210d;
    const double trendPadLeft = 44d;
    const double trendPadRight = 18d;
    const double trendPadTop = 16d;
    const double trendPadBottom = 28d;
    var trendPlotWidth = trendWidth - trendPadLeft - trendPadRight;
    var trendPlotHeight = trendHeight - trendPadTop - trendPadBottom;
    var trendMax = trendCount == 0
        ? 1
        : Math.Max(1, trendPoints.Max(x => Math.Max(x.AToB, x.BToA)));
    var trendXAxisStep = trendCount <= 10 ? 1 : Math.Max(1, (int)Math.Ceiling(trendCount / 8.0));
    var xAxisMeaning = Model.TrendBucket == "hour"
        ? "Hour of selected date (local time)"
        : "Date (local time)";
    var aSeriesPoints = new List<string>(trendCount);
    var bSeriesPoints = new List<string>(trendCount);
    for (var i = 0; i < trendCount; i++)
    {
        var x = TrendX(i, trendCount, trendPadLeft, trendPlotWidth);
        var aY = TrendY(trendPoints[i].AToB, trendMax, trendPadTop, trendPlotHeight);
        var bY = TrendY(trendPoints[i].BToA, trendMax, trendPadTop, trendPlotHeight);
        aSeriesPoints.Add($"{Fmt(x)},{Fmt(aY)}");
        bSeriesPoints.Add($"{Fmt(x)},{Fmt(bY)}");
    }
    var aSeriesPath = string.Join(" ", aSeriesPoints);
    var bSeriesPath = string.Join(" ", bSeriesPoints);
    var peakPoint = trendCount == 0
        ? null
        : trendPoints
            .Select(x => new
            {
                x.Label,
                Total = x.AToB + x.BToA,
            })
            .OrderByDescending(x => x.Total)
            .First();
}

<div class="topbar">
    <div class="title">
        <h2>Dashboard</h2>
        <p>Totals + review progress for current filter window.</p>
    </div>

    <form method="get" class="filters">
        <div class="field">
            <label for="siteId">Site</label>
            <input id="siteId" type="text" name="siteId" value="@Model.SiteId" placeholder="subang" />
        </div>
        <div class="field">
            <label for="cameraId">Camera</label>
            <input id="cameraId" type="text" name="cameraId" value="@Model.CameraId" placeholder="cam_01" />
        </div>
        <div class="field">
            <label for="dateFrom">Date From</label>
            <input id="dateFrom" type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="field">
            <label for="dateTo">Date To</label>
            <input id="dateTo" type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))" />
        </div>
        <button type="submit" class="btn primary">Apply</button>
    </form>
</div>

<div class="grid">
    <section class="mode-banner" aria-label="Review flow status">
        <div class="mode-copy">
            <div class="mode-eyebrow">OPS PULSE</div>
            <div class="mode-title">Review lane is active with @pending pending event(s)</div>
            <div class="mode-desc">Estimated queue clearance: @(queueEstimateMinutes == 0 ? "cleared" : $"~{queueEstimateMinutes} min"). Completion rate: @reviewCompletion%.</div>
        </div>
        <div class="mode-tags">
            <span class="pill">pending @pending</span>
            <span class="pill ink">reviewed @reviewed</span>
            <span class="pill brand">observed @totalObserved</span>
        </div>
    </section>

    <section class="kpis" aria-label="Key metrics">
        <article class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div class="kpi-label">A_TO_B</div>
                    <div class="kpi-accent dir-a">A→B</div>
                </div>
                <div class="kpi-value">@Model.TotalAToB.ToString("N0")</div>
                <div class="kpi-hint">Crossings from side A to side B.</div>
            </div>
        </article>

        <article class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div class="kpi-label">B_TO_A</div>
                    <div class="kpi-accent dir-b">B→A</div>
                </div>
                <div class="kpi-value">@Model.TotalBToA.ToString("N0")</div>
                <div class="kpi-hint">Crossings from side B to side A.</div>
            </div>
        </article>

        <article class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div class="kpi-label">Pending reviews</div>
                    <div class="kpi-accent">P</div>
                </div>
                <div class="kpi-value">@pending.ToString("N0")</div>
                <div class="kpi-hint">Awaiting reviewer decisions.</div>
            </div>
        </article>

        <article class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div class="kpi-label">Qualified YES</div>
                    <div class="kpi-accent yes">Y</div>
                </div>
                <div class="kpi-value">@Model.TotalQualified.ToString("N0")</div>
                <div class="kpi-hint">Criteria matched.</div>
            </div>
        </article>

        <article class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div class="kpi-label">Qualified NO</div>
                    <div class="kpi-accent no">N</div>
                </div>
                <div class="kpi-value">@Model.TotalNotQualified.ToString("N0")</div>
                <div class="kpi-hint">Criteria not matched.</div>
            </div>
        </article>
    </section>

    <section class="row2">
        <section class="card dashboard-trend" aria-label="Live trend chart">
            <div class="pad">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Event trend (@Model.TrendBucket)</div>
                        <div class="kpi-hint">@Model.TrendRangeLabel</div>
                    </div>
                    <div class="pill">points @trendCount</div>
                </div>

                @if (trendCount == 0)
                {
                    <div class="trend-empty">No events with timestamps for this filter window.</div>
                }
                else
                {
                    <div class="trend-context">
                        <p class="trend-meaning">Simple direction trend: A→B and B→A per time bucket.</p>
                        <div class="trend-meta-pills">
                            <span class="pill">timezone @Model.TrendTimezone</span>
                            @if (peakPoint is not null)
                            {
                                <span class="pill ink">peak @peakPoint.Total at @peakPoint.Label</span>
                            }
                        </div>
                    </div>

                    <div class="trend-legend" aria-label="Series explanation">
                        <span class="trend-key">
                            <span class="trend-key-line dir-a" aria-hidden="true"></span>
                            A→B
                        </span>
                        <span class="trend-key">
                            <span class="trend-key-line dir-b" aria-hidden="true"></span>
                            B→A
                        </span>
                    </div>
                    <div class="trend-hint">Hover line points to see exact values for each bucket.</div>

                    <div class="trend-chart-wrap">
                        <svg class="trend-svg" viewBox="0 0 920 210" preserveAspectRatio="none" role="img" aria-label="Line chart for A to B and B to A crossings by time bucket" aria-describedby="trend-chart-desc" xmlns:svg="http://www.w3.org/2000/svg">
                            @for (var i = 0; i <= 2; i++)
                            {
                                var y = trendPadTop + (trendPlotHeight * i / 2.0);
                                var tickValue = (int)Math.Round(trendMax * (2 - i) / 2.0);
                                <line class="trend-grid-line" x1="@Fmt(trendPadLeft)" y1="@Fmt(y)" x2="@Fmt(trendPadLeft + trendPlotWidth)" y2="@Fmt(y)"></line>
                                <svg:text class="trend-grid-value" x="@Fmt(trendPadLeft - 6)" y="@Fmt(y + 4)">@tickValue</svg:text>
                            }

                            <polyline class="trend-line dir-a" points="@aSeriesPath"></polyline>
                            <polyline class="trend-line dir-b" points="@bSeriesPath"></polyline>

                            @for (var i = 0; i < trendCount; i++)
                            {
                                var pointX = TrendX(i, trendCount, trendPadLeft, trendPlotWidth);
                                var pointAY = TrendY(trendPoints[i].AToB, trendMax, trendPadTop, trendPlotHeight);
                                var pointBY = TrendY(trendPoints[i].BToA, trendMax, trendPadTop, trendPlotHeight);
                                <circle class="trend-point dir-a" cx="@Fmt(pointX)" cy="@Fmt(pointAY)" r="2.8">
                                    <title>@($"{trendPoints[i].TooltipLabel} | A→B: {trendPoints[i].AToB}")</title>
                                </circle>
                                <circle class="trend-point dir-b" cx="@Fmt(pointX)" cy="@Fmt(pointBY)" r="2.8">
                                    <title>@($"{trendPoints[i].TooltipLabel} | B→A: {trendPoints[i].BToA}")</title>
                                </circle>
                            }

                            @{
                                var lastIndex = trendCount - 1;
                                var lastX = TrendX(lastIndex, trendCount, trendPadLeft, trendPlotWidth);
                                var lastATrendY = TrendY(trendPoints[lastIndex].AToB, trendMax, trendPadTop, trendPlotHeight);
                                var lastBTrendY = TrendY(trendPoints[lastIndex].BToA, trendMax, trendPadTop, trendPlotHeight);
                            }
                            <circle class="trend-focus-dot dir-a" cx="@Fmt(lastX)" cy="@Fmt(lastATrendY)" r="3.5">
                                <title>@($"Latest A→B: {trendPoints[trendCount - 1].AToB}")</title>
                            </circle>
                            <circle class="trend-focus-dot dir-b" cx="@Fmt(lastX)" cy="@Fmt(lastBTrendY)" r="3.5">
                                <title>@($"Latest B→A: {trendPoints[trendCount - 1].BToA}")</title>
                            </circle>

                            @for (var i = 0; i < trendCount; i += trendXAxisStep)
                            {
                                var x = TrendX(i, trendCount, trendPadLeft, trendPlotWidth);
                                <svg:text class="trend-axis-label" x="@Fmt(x)" y="@Fmt(trendPadTop + trendPlotHeight + 18)">@trendPoints[i].Label</svg:text>
                            }
                            @if (trendCount > 1 && ((trendCount - 1) % trendXAxisStep) != 0)
                            {
                                var lastTickX = TrendX(trendCount - 1, trendCount, trendPadLeft, trendPlotWidth);
                                <svg:text class="trend-axis-label" x="@Fmt(lastTickX)" y="@Fmt(trendPadTop + trendPlotHeight + 18)">@trendPoints[trendCount - 1].Label</svg:text>
                            }
                        </svg>
                        <div class="trend-x-title">X-axis: @xAxisMeaning. Y-axis: Events per bucket.</div>
                        <p id="trend-chart-desc" class="visually-hidden">
                            Line chart with two series per time bucket: A to B crossings and B to A crossings. Y-axis is events per bucket. X-axis is @xAxisMeaning.
                        </p>
                    </div>
                    <div class="trend-value-strip" aria-label="Latest trend values">
                        <span class="pill dir-a">latest A→B @trendPoints[trendCount - 1].AToB</span>
                        <span class="pill dir-b">latest B→A @trendPoints[trendCount - 1].BToA</span>
                    </div>
                }
            </div>
        </section>

        <div class="card">
            <div class="pad">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Review queue</div>
                        <div class="kpi-hint">Jump straight into YES/NO labeling.</div>
                    </div>
                    <div class="kpi-accent">↳</div>
                </div>
                <div class="btn-row" style="margin-top: 14px;">
                    <a class="btn primary" asp-controller="Events" asp-action="ReviewQueue" style="text-decoration:none;">Open Review</a>
                    <a class="btn secondary" asp-controller="Events" asp-action="Index" style="text-decoration:none;">Open Browser</a>
                </div>
                <div style="margin-top: 14px; color: var(--muted); font-size: 12px; line-height: 1.4;">
                    <p style="margin:0;">Qualified YES/NO is saved in SQL and exported as reviewed CSV for audit/training.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="pad">
            <div class="kpi-top">
                <div>
                    <div class="kpi-label">Recent events</div>
                    <div class="kpi-hint">One row per line-crossing event.</div>
                </div>
                <div class="pill">latest @Model.RecentEvents.Count</div>
            </div>

            <div class="table-scroll" style="margin-top: 10px;">
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Thumb</th>
                            <th scope="col">Time (Local)</th>
                            <th scope="col">Site/Camera</th>
                            <th scope="col">Direction</th>
                            <th scope="col">Class</th>
                            <th scope="col">Review</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.RecentEvents.Count == 0)
                    {
                        <tr><td colspan="7">No events found for this filter.</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentEvents)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                                    {
                                        <img src="@item.ThumbnailUrl" alt="@($"Thumbnail for event {item.EventUid} ({item.ClassName}, {item.Direction})")" class="thumb-inline" loading="lazy" decoding="async" fetchpriority="low" width="44" height="34" />
                                    }
                                    else
                                    {
                                        <div class="thumb" title="thumbnail unavailable"></div>
                                    }
                                </td>
                                <td><span class="pill">@item.OccurredAtLocal?.ToString("yyyy-MM-dd HH:mm:ss")</span></td>
                                <td>@item.SiteId / @item.CameraId</td>
                                <td><span class="pill @(item.Direction == "A_TO_B" ? "dir-a" : "dir-b")">@item.Direction</span></td>
                                <td>@item.ClassName</td>
                                <td><span class="pill @StatusClass(item.ReviewStatus)">@item.ReviewStatus</span></td>
                                <td>
                                    <a asp-controller="Events"
                                       asp-action="Detail"
                                       asp-route-eventUid="@item.EventUid"
                                       class="pill"
                                       style="text-decoration:none;"
                                       aria-label="@($"Inspect event {item.EventUid}")">Inspect</a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@functions {
    private static double TrendY(int value, int maxValue, double padTop, double plotHeight)
    {
        var safeMax = Math.Max(1, maxValue);
        return padTop + plotHeight - ((plotHeight * value) / safeMax);
    }

    private static double TrendX(int index, int totalPoints, double padLeft, double plotWidth)
    {
        if (totalPoints <= 1)
        {
            return padLeft + (plotWidth / 2d);
        }

        return padLeft + ((plotWidth * index) / (totalPoints - 1d));
    }

    private static string Fmt(double value)
    {
        return value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string StatusClass(string? status)
    {
        return (status ?? string.Empty).ToUpperInvariant() switch
        {
            ReviewStatuses.Qualified => "yes",
            ReviewStatuses.NotQualified => "no",
            _ => "pending",
        };
    }
}
