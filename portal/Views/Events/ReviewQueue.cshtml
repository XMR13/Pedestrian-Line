@model ReviewQueueViewModel
@{
    ViewData["Title"] = "Review Queue";

    var currentPosition = Model.Current is null ? 0 : 1;
    var queueTotal = Math.Max(Model.PendingCount, Model.Current is null ? 0 : 1);
    var next = Model.Upcoming.FirstOrDefault();
}

<div class="topbar">
    <div class="title">
        <h2>Review Queue</h2>
        <p>Fast Yes/No labeling + notes per crossing event.</p>
    </div>
    <div class="filters">
        <span class="hint"><span class="kbd">Y</span> yes</span>
        <span class="hint"><span class="kbd">N</span> no</span>
        <span class="hint"><span class="kbd">S</span> save notes</span>
        <span class="hint"><span class="kbd">J</span>/<span class="kbd">K</span> navigate</span>
    </div>
</div>

<section class="mode-banner queue">
    <div class="mode-copy">
        <div class="mode-eyebrow">QUEUE MODE</div>
        <div class="mode-title">Rapid event triage</div>
        <div class="mode-desc">Optimized for speed: review, label, and move to the next event.</div>
    </div>
    <div class="mode-tags">
        <span class="pill">item @currentPosition / @queueTotal</span>
        <span class="pill ink">hotkeys J/K + Y/N</span>
        <span class="pill">pending focus</span>
    </div>
</section>

<section class="queue-status-grid" aria-live="polite">
    <article class="queue-status-card">
        <div class="label">Current position</div>
        <div class="value">@currentPosition / @queueTotal</div>
    </article>
    <article class="queue-status-card">
        <div class="label">Pending</div>
        <div class="value">@Model.PendingCount</div>
    </article>
    <article class="queue-status-card yes">
        <div class="label">Qualified YES</div>
        <div class="value">@Model.QualifiedCount</div>
    </article>
    <article class="queue-status-card no">
        <div class="label">Qualified NO</div>
        <div class="value">@Model.NotQualifiedCount</div>
    </article>
</section>

@if (Model.Current is null)
{
    <section class="panel">
        <h3>Queue Empty</h3>
        <p class="mode-desc">No pending events right now. New events will appear here when ingested.</p>
    </section>
}
else
{
    <div class="two-col queue-layout">
        <div class="big-thumb queue-thumb" aria-label="Event thumbnail">
            @if (!string.IsNullOrWhiteSpace(Model.Current.ThumbnailUrl))
            {
                <img src="@Model.Current.ThumbnailUrl" alt="@($"Thumbnail for event {Model.Current.EventUid} ({Model.Current.ClassName}, {Model.Current.Direction})")" class="big-thumb-image" />
            }
            <div style="position:absolute; left:14px; top:14px; display:flex; gap:10px; flex-wrap: wrap;">
                <span class="pill @(Model.Current.Direction == "A_TO_B" ? "dir-a" : "dir-b")">@Model.Current.Direction</span>
                <span class="pill">@Model.Current.ClassName</span>
                <span class="pill">conf @(Model.Current.Confidence?.ToString("0.00") ?? "n/a")</span>
            </div>
            <div style="position:absolute; right:14px; top:14px;">
                <span class="pill">@Model.Current.EventUid</span>
            </div>
        </div>

        <div class="panel queue-panel">
            <h3>Current event</h3>
            <div class="meta">
                <div class="row"><div class="key">Occurred (Local)</div><div class="val">@Model.Current.OccurredAtLocal?.ToString("yyyy-MM-dd HH:mm:ss zzz")</div></div>
                <div class="row"><div class="key">Occurred (UTC)</div><div class="val">@Model.Current.OccurredAtUtc?.ToString("yyyy-MM-ddTHH:mm:ssZ")</div></div>
                <div class="row"><div class="key">Video time</div><div class="val">@(Model.Current.VideoTimeS?.ToString("0.###") ?? "-") s</div></div>
                <div class="row"><div class="key">Direction</div><div class="val">@Model.Current.Direction</div></div>
                <div class="row"><div class="key">Track</div><div class="val">track_id @Model.Current.TrackId</div></div>
                <div class="row"><div class="key">Class</div><div class="val">@Model.Current.ClassName</div></div>
            </div>

            <div class="queue-next-strip" role="status" aria-live="polite">
                <div class="queue-next-copy">
                    <div class="head">Next target in queue</div>
                    <div class="body">
                        @if (next is null)
                        {
                            <text>No next item</text>
                        }
                        else
                        {
                            <text>@next.EventUid • @next.ClassName • @next.Direction</text>
                        }
                    </div>
                </div>
                <span class="pill">after this: @(Math.Max(Model.PendingCount - 1, 0)) pending</span>
            </div>

            <form method="post" action="/api/events/@Model.Current.EventUid/review" id="review-form" style="margin-top: 12px;" data-disable-on-submit>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <input type="hidden" name="reviewStatus" id="review-status" value="PENDING" />

                <label for="review-notes" style="font-size: 11px; color: var(--muted); letter-spacing: 0.2px;">Notes</label>
                <textarea id="review-notes" name="notes" placeholder="Optional notes (e.g., cargo looks like paper, covered with tarp).">@Model.Current.Notes</textarea>

                <div class="panel" style="margin-top: 12px;">
                    <h3 style="margin-bottom: 8px;">Upcoming events</h3>
                    <div class="queue-mini-list">
                        @if (Model.Upcoming.Count == 0)
                        {
                            <div class="queue-mini-item">
                                <div class="queue-mini-main">
                                    <strong>No upcoming pending events</strong>
                                    <span>Queue is almost cleared</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            for (var i = 0; i < Model.Upcoming.Count; i++)
                            {
                                var item = Model.Upcoming[i];
                                <a class="queue-mini-item @(i == 0 ? "active" : string.Empty)" asp-action="Detail" asp-route-eventUid="@item.EventUid" data-queue-link>
                                    <div class="queue-mini-main">
                                        <strong>@item.EventUid • @item.ClassName • @item.Direction</strong>
                                        <span>@item.OccurredAtLocal?.ToString("HH:mm:ss") local • @item.SiteId/@item.CameraId</span>
                                    </div>
                                    <span class="pill">@(i == 0 ? "next" : (i + 1).ToString())</span>
                                </a>
                            }
                        }
                    </div>
                </div>

                <div class="queue-actions">
                    <div class="btn-row equal">
                        <button class="btn yes" type="submit" data-review-status="QUALIFIED">Qualified YES</button>
                        <button class="btn no" type="submit" data-review-status="NOT_QUALIFIED">Qualified NO</button>
                    </div>
                    <div class="btn-row" style="margin-top: 10px;">
                        <button class="btn secondary" type="submit" data-review-status="PENDING">Save Notes</button>
                        <a class="btn" asp-action="Detail" asp-route-eventUid="@Model.Current.EventUid" data-open-detail>Open Detail</a>
                    </div>
                    <div class="queue-help">
                        <span class="hint"><span class="kbd">Y</span> mark yes</span>
                        <span class="hint"><span class="kbd">N</span> mark no</span>
                        <span class="hint"><span class="kbd">S</span> save notes</span>
                        <span class="hint"><span class="kbd">J</span>/<span class="kbd">K</span> navigate</span>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
