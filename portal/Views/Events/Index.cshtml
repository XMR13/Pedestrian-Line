@model EventListPageViewModel
@{
    ViewData["Title"] = "Event Browser";
}

<div class="topbar">
    <div class="title">
        <h2>Event Browser</h2>
        <p>Step 1: search and shortlist events. Step 2: open one row to inspect full evidence.</p>
    </div>
    <a class="btn secondary" asp-action="ExportCsv"
       asp-route-siteId="@Model.SiteId"
       asp-route-cameraId="@Model.CameraId"
       asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
       asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
       asp-route-direction="@Model.Direction"
       asp-route-className="@Model.ClassName"
       asp-route-reviewStatus="@Model.ReviewStatus">Export Reviewed CSV</a>
</div>

<form method="get" class="filters event-browser-filters" style="margin-bottom: 14px;">
    <div class="field">
        <label for="siteId">Site</label>
        <input id="siteId" type="text" name="siteId" value="@Model.SiteId" placeholder="subang" />
    </div>
    <div class="field">
        <label for="cameraId">Camera</label>
        <input id="cameraId" type="text" name="cameraId" value="@Model.CameraId" placeholder="cam_01" />
    </div>
    <div class="field">
        <label for="dateFrom">Date From</label>
        <input id="dateFrom" type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="field">
        <label for="dateTo">Date To</label>
        <input id="dateTo" type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="field">
        <label for="direction">Direction</label>
        <select id="direction" name="direction">
            <option value="">All</option>
            <option value="A_TO_B" selected="@(Model.Direction == "A_TO_B")">A_TO_B</option>
            <option value="B_TO_A" selected="@(Model.Direction == "B_TO_A")">B_TO_A</option>
        </select>
    </div>
    <div class="field">
        <label for="className">Class</label>
        <input id="className" type="text" name="className" value="@Model.ClassName" placeholder="truck" />
    </div>
    <div class="field">
        <label for="reviewStatus">Review</label>
        <select id="reviewStatus" name="reviewStatus">
            <option value="">All</option>
            <option value="PENDING" selected="@(Model.ReviewStatus == "PENDING")">PENDING</option>
            <option value="QUALIFIED" selected="@(Model.ReviewStatus == "QUALIFIED")">QUALIFIED</option>
            <option value="NOT_QUALIFIED" selected="@(Model.ReviewStatus == "NOT_QUALIFIED")">NOT_QUALIFIED</option>
        </select>
    </div>
    <button type="submit" class="btn primary">Apply</button>
</form>

<section class="mode-banner">
    <div class="mode-copy">
        <div class="mode-eyebrow">BROWSER MODE</div>
        <div class="mode-title">@Model.Total total event(s) matched</div>
        <div class="mode-desc">Page @Model.Page of @Model.TotalPages with current filters.</div>
    </div>
    <div class="mode-tags">
        <span class="pill">page size @Model.PageSize</span>
        <span class="pill @(Model.Direction == "A_TO_B" ? "dir-a" : (Model.Direction == "B_TO_A" ? "dir-b" : "ink"))">direction @(string.IsNullOrWhiteSpace(Model.Direction) ? "all" : Model.Direction)</span>
        <span class="pill brand">review @(string.IsNullOrWhiteSpace(Model.ReviewStatus) ? "all" : Model.ReviewStatus)</span>
    </div>
</section>

<section class="card">
    <div class="pad">
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th scope="col">Thumb</th>
                        <th scope="col">Time (Local)</th>
                        <th scope="col">Site/Camera</th>
                        <th scope="col">Class</th>
                        <th scope="col">Direction</th>
                        <th scope="col">Review</th>
                        <th scope="col">Inspect</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="7">No events match current filters.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="@($"Thumbnail for event {item.EventUid} ({item.ClassName}, {item.Direction})")" class="thumb-inline" loading="lazy" decoding="async" fetchpriority="low" width="44" height="34" />
                                }
                                else
                                {
                                    <div class="thumb" title="thumbnail unavailable"></div>
                                }
                            </td>
                            <td>@item.OccurredAtLocal?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@item.SiteId / @item.CameraId</td>
                            <td>@item.ClassName</td>
                            <td><span class="pill @(item.Direction == "A_TO_B" ? "dir-a" : "dir-b")">@item.Direction</span></td>
                            <td><span class="pill @StatusClass(item.ReviewStatus)">@item.ReviewStatus</span></td>
                            <td>
                                <a asp-action="Detail" asp-route-eventUid="@item.EventUid" class="btn secondary btn-compact action-inspect">Inspect</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <div class="btn-row" style="margin-top: 14px; justify-content: space-between;">
            <span class="hint">Page @Model.Page / @Model.TotalPages (@Model.Total total)</span>
            <div class="btn-row">
                @if (Model.Page > 1)
                {
                    <a class="btn secondary" asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-siteId="@Model.SiteId"
                       asp-route-cameraId="@Model.CameraId"
                       asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
                       asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
                       asp-route-direction="@Model.Direction"
                       asp-route-className="@Model.ClassName"
                       asp-route-reviewStatus="@Model.ReviewStatus">Previous</a>
                }
                @if (Model.Page < Model.TotalPages)
                {
                    <a class="btn secondary" asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-siteId="@Model.SiteId"
                       asp-route-cameraId="@Model.CameraId"
                       asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
                       asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? Model.Date?.ToString("yyyy-MM-dd"))"
                       asp-route-direction="@Model.Direction"
                       asp-route-className="@Model.ClassName"
                       asp-route-reviewStatus="@Model.ReviewStatus">Next</a>
                }
            </div>
        </div>
    </div>
</section>

@functions {
    private static string StatusClass(string? status)
    {
        return (status ?? string.Empty).ToUpperInvariant() switch
        {
            ReviewStatuses.Qualified => "yes",
            ReviewStatuses.NotQualified => "no",
            _ => "pending",
        };
    }
}
