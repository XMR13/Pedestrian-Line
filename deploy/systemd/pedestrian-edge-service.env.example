# Spool root shared with the detector runtime
PLC_SPOOL_DIR=/data/traffic_runs/

# Service bind
PLC_SERVICE_HOST=127.0.0.1
PLC_SERVICE_PORT=8080
PLC_SERVICE_EXPOSURE=loopback

# Leave empty to follow the safe default:
# - loopback -> docs on
# - lan      -> docs off
PLC_SERVICE_DOCS=

# Comma-separated trusted hosts used only when exposure=lan.
# Example:
# PLC_SERVICE_TRUSTED_HOSTS=localhost,127.0.0.1,192.168.1.50
PLC_SERVICE_TRUSTED_HOSTS=

# Local operator login (temporary until company auth is finalized)
EDGE_UI_USERNAME=admin
EDGE_UI_PASSWORD=password

# Required for mutation endpoints when operators trigger retry/retention actions
EDGE_SERVICE_API_KEY=api_key_example

# Optional uploader wiring for service sync endpoints
# If set, `/sync/*` endpoints can use the same delivery backend config.
# Recommended current deployment:
# - let `pedestrian-single-loop.service` own automatic uploading,
# - leave PLC_PORTAL_API_BASE_URL unset here unless you want manual retry/sync
#   from the FastAPI service against the same backend.
# PLC_PORTAL_API_BASE_URL=http://127.0.0.1:5000
# PORTAL_API_KEY=replace-me

# Retention
PLC_SERVICE_RETENTION_ENABLED=1
PLC_SERVICE_RETENTION_MAX_AGE_DAYS=90
PLC_SERVICE_RETENTION_AUTO_INTERVAL_S=3600

# Optional runtime title / runner override
# PLC_SERVICE_TITLE=Pedestrian Line Edge Service
# PYTHON_BIN=/opt/pedestrian-line/.venv/bin/python
# UV_BIN=/usr/local/bin/uv

# Temporary LAN/IP example:
# PLC_SERVICE_HOST=0.0.0.0
# PLC_SERVICE_EXPOSURE=lan
# PLC_SERVICE_TRUSTED_HOSTS=localhost,127.0.0.1,192.168.1.50
