# Detector loop input
# Keep the real RTSP URL in /etc/vehicle_count/single_loop.env on the Jetson.
# Do not hard-code camera IPs or credentials in scripts committed to Git.
PLC_INPUT_PATH=
PLC_RTSP_URL=rtsp://WINDOWS_BRIDGE_IP:8554/live/ezviz_cam01

# TensorRT detector runtime
PLC_BACKEND=tensorrt
PLC_MODEL_PATH=Models/models.engine
PLC_CLASS_NAMES=Models/metadata_vehicle.yaml
PLC_CONFIDENCE=0.65

# Camera/line config
PLC_SITE_ID=subang
PLC_CAMERA_ID=cam_01
PLC_CAMERA=camera_subang

# Shared spool root read by edge_service.service
PLC_SPOOL_DIR=/var/lib/pedline/traffic_runs
PLC_PORTAL_UPLOAD_ENABLED=0

# RTSP capture settings
PLC_RTSP_CAPTURE_BACKEND=gstreamer
PLC_RTSP_TRANSPORT=tcp
PLC_RTSP_CODEC=h264
PLC_RTSP_LATENCY_MS=120

# Live-loop performance settings
PLC_FRAME_STRIDE=1
PLC_QUEUE_SIZE=3
PLC_QUEUE_POLICY=drop_oldest
PLC_HEADLESS_STATUS_EVERY_S=10

# Evidence output
PLC_SPOOL_THUMBNAILS=1
PLC_SPOOL_SCENE_THUMBNAILS=1
PLC_SPOOL_THUMB_MAX_SIDE=256
PLC_SPOOL_SCENE_THUMB_MAX_SIDE=1280
PLC_SPOOL_SCENE_THUMB_QUALITY=95

# Optional safety/debug knobs
# PLC_TARGET_FPS=20
# PLC_ALLOW_ALL_CLASSES=1
# PLC_MAX_SECONDS=60
# PYTHON_BIN=/opt/pedestrian_line_counter/.venv/bin/python
# UV_BIN=/usr/local/bin/uv
