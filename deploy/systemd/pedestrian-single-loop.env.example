# Required secrets
PLC_RTSP_URL=rtsp://user:pass@camera-host:554/stream
# Required only when PLC_PORTAL_UPLOAD_ENABLED=1
PORTAL_API_KEY=replace-me

# Runtime identity
PLC_SITE_ID=subang
PLC_CAMERA_ID=cam_01
PLC_CAMERA=camera_subang
# PLC_LINE_JSON=config/cameras/camera_subang.json

# Model runtime
PLC_BACKEND=tensorrt
PLC_MODEL_PATH=Models/vehicle_subclasses.onnx
PLC_CLASS_IDS=0,1,2

# RTSP capture + latency controls
PLC_RTSP_CAPTURE_BACKEND=gstreamer
PLC_RTSP_TRANSPORT=tcp
PLC_RTSP_CODEC=h264
PLC_RTSP_LATENCY_MS=120
PLC_QUEUE_SIZE=3
PLC_QUEUE_POLICY=drop_oldest
PLC_TARGET_FPS=12
PLC_FRAME_STRIDE=1

# Spool + upload
PLC_SPOOL_DIR=/var/lib/pedline/traffic_runs
PLC_PORTAL_UPLOAD_ENABLED=1
PLC_PORTAL_API_BASE_URL=http://127.0.0.1:5000
PLC_PORTAL_UPLOAD_INTERVAL_S=10
PLC_PORTAL_UPLOAD_MAX_RUNS_PER_PASS=2
PLC_PORTAL_UPLOAD_EVENTS_BATCH_SIZE=200
PLC_HEADLESS_STATUS_EVERY_S=10
# PLC_HEADLESS_STATUS_JSON=/var/lib/pedline/status/cam_01.json
# PLC_MAX_SECONDS=30
# PLC_MAX_FRAMES=300

# Optional if uv is not on default PATH
# UV_BIN=/usr/local/bin/uv

# If backend upload is not ready yet, you can still run detect+spool locally:
# PLC_PORTAL_UPLOAD_ENABLED=0
